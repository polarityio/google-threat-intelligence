{{#if vulnerabilities.length}}
  <div>
    {{#each vulnerabilities as |vulnerability vulnIndex|}}
      <div>
        <div>
          <h1 class="p-title">
            {{vulnerability.name}}
          </h1>
          <div>
            <a class="p-link" href="https://www.virustotal.com/gui/collection/{{vulnerability.id}}">
              View Vulnerability in GTI
              <svg
                class="gti-icon"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M12.0014 8.57257C11.4758 8.57257 10.9845 8.69824 10.5274 8.9153L12.7784 11.1659C12.9955 11.3715 13.1327 11.6686 13.1327 11.9999H15.418C15.418 10.1149 13.8754 8.57257 11.99 8.57257H12.0014Z"
                  fill="#FBBC04"
                ></path>
                <path
                  d="M12.0014 13.1423C11.373 13.1423 10.8588 12.6282 10.8588 11.9999H8.57347C8.57347 13.8849 10.1161 15.4271 12.0014 15.4271C13.8868 15.4271 15.4294 13.8849 15.4294 11.9999H13.1441C13.1441 12.6282 12.6299 13.1423 12.0014 13.1423Z"
                  fill="#34A853"
                ></path>
                <path
                  d="M14.4696 17.1408C13.3498 17.6777 12.0357 17.8719 10.6531 17.5521C8.5849 17.0722 6.92805 15.4043 6.44813 13.3479C6.3453 12.891 6.28816 12.4454 6.28816 11.9999H4.00286C4.00286 12.4911 4.04856 12.9938 4.13997 13.4964C4.73415 16.6952 7.30512 19.2657 10.5046 19.8598C12.2757 20.1911 13.9668 19.9169 15.4065 19.2314C16.1264 18.8887 16.3207 17.9405 15.7493 17.3807C15.4065 17.038 14.8923 16.9466 14.4696 17.1522V17.1408Z"
                  fill="#4285F4"
                ></path>
                <path
                  d="M19.223 15.4157C19.7143 14.3761 20 13.2223 20 11.9999H17.7147C17.7147 12.8795 17.509 13.7135 17.1548 14.4561C16.9491 14.8902 17.0291 15.4043 17.3719 15.747C17.9318 16.3068 18.8802 16.1355 19.223 15.4043V15.4157Z"
                  fill="#4285F4"
                ></path>
                <path
                  d="M13.3041 4.10567C12.6185 3.99143 12.0014 4.55122 12.0014 5.2481C12.0014 5.80789 12.4128 6.27629 12.9727 6.36768C15.6579 6.83608 17.7147 9.17806 17.7147 11.9999H20C20 8.03563 17.0977 4.73401 13.3041 4.10567Z"
                  fill="#FBBC04"
                ></path>
                <path
                  d="M10.5274 8.9153L5.95679 4.33416C5.51116 3.88861 4.77986 3.88861 4.33423 4.33416C3.88859 4.77971 3.88859 5.51086 4.33423 5.95641L5.60257 7.22451C4.60846 8.54972 4.00286 10.2062 4.00286 11.9999H6.28816C6.28816 10.8346 6.64239 9.7607 7.23656 8.85818L8.90484 10.5261C8.68773 10.9717 8.56204 11.4743 8.56204 11.9999H10.8473C10.8473 11.3715 11.3615 10.8574 11.99 10.8574C12.2871 10.8574 12.5728 10.9831 12.7784 11.1659L10.5274 8.9153Z"
                  fill="#EA4335"
                ></path>
              </svg>
            </a>
          </div>

          <div>
            {{! EXECUTIVE OVERVIEW }}
            {{#if vulnerability.htmlExecutiveSummary}}
              <div>
                <h2 class="p-title">
                  Executive Summary
                </h2>
                <div class="scrollable-block short html">
                  {{{vulnerability.htmlExecutiveSummary}}}
                </div>
              </div>
            {{/if}}

            {{#if vulnerability.htmlDescription}}
              <div>
                <h2 class="p-title">
                  Description
                </h2>
                <div class="scrollable-block short">
                  {{{vulnerability.htmlDescription}}}
                </div>
              </div>
            {{/if}}

            {{#if vulnerability.alt_names}}
              <div>
                <h2 class="p-title">
                  Alternate Names
                  {{#if (gt vulnerability.alt_names.length 1)}}
                    ({{vulnerability.alt_names.length}})
                  {{/if}}
                </h2>
                {{#each vulnerability.alt_names as |name|}}
                  <span class="pill-tag">
                    {{name}}
                  </span>
                {{/each}}
              </div>
            {{/if}}

            {{#if vulnerability.tags}}
              <div>
                <h2 class="p-title">
                  Tags
                  {{#if (gt vulnerability.tags.length 1)}}
                    ({{vulnerability.tags.length}})
                  {{/if}}
                </h2>
                {{#each vulnerability.tags as |tag|}}
                  <span class="pill-tag">
                    {{tag}}
                  </span>
                {{/each}}
              </div>
            {{/if}}

            {{! CORE RISK ASSESSMENT - Always visible }}
            {{#if
              (or
                vulnerability.risk_rating
                vulnerability.priority
                vulnerability.cvssScore
                vulnerability.exploitabilityMetrics.epssScore
              )
            }}
              <h2 class="p-title">
                Risk Assessment
              </h2>
            {{/if}}
            {{#if vulnerability.risk_rating}}
              <div>
                <span class="p-key">
                  Risk Rating:
                </span>
                <span class="p-value">
                  {{vulnerability.risk_rating}}
                  {{#if vulnerability.predicted_risk_rating}}
                    (Predicted: {{vulnerability.predicted_risk_rating}})
                  {{/if}}
                </span>
              </div>
            {{/if}}
            {{#if vulnerability.priority}}
              <div>
                <span class="p-key">
                  Priority:
                </span>
                <span class="p-value">
                  {{vulnerability.priority}}
                </span>
              </div>
            {{/if}}
            {{#if vulnerability.cvssScore}}
              <div>
                <span class="p-key">
                  CVSS Score:
                </span>
                <span class="p-value">
                  {{vulnerability.cvssScore}}{{#if vulnerability.severity}}
                    ({{vulnerability.severity}})
                  {{/if}}
                </span>
              </div>
            {{/if}}
            {{#if vulnerability.exploitabilityMetrics.epssScore}}
              <div>
                <span class="p-key">
                  EPSS Score:
                </span>
                <span class="p-value">
                  {{vulnerability.exploitabilityMetrics.epssScore}} ({{
                    vulnerability.exploitabilityMetrics.epssPercentile
                  }}% percentile)
                  {{#if vulnerability.exploitabilityMetrics.hasExploit}}
                    - Exploit Available
                  {{/if}}
                </span>
              </div>
            {{/if}}

            {{! DROPDOWN ALTERNATIVE INDIVIDUAL FIELDS DISPLAYS START }}

            {{! CRITICAL TIMELINE - Individual Fields }}
            {{#if
              (not
                (or
                  (and vulnerability.cisa_known_exploited vulnerability.date_of_disclosure)
                  (and vulnerability.cisa_known_exploited vulnerability.exploitation.first_exploitation)
                  (and vulnerability.date_of_disclosure vulnerability.exploitation.first_exploitation)
                )
              )
            }}
              {{#if vulnerability.date_of_disclosure}}
                <div>
                  <span class="p-key">
                    Disclosure Date:
                  </span>
                  <span class="p-value">
                    {{moment-format vulnerability.date_of_disclosure "YYYY-MM-DD" timeZone=timezone}}
                  </span>
                </div>
              {{/if}}
              {{#if vulnerability.exploitation.first_exploitation}}
                <div>
                  <span class="p-key">
                    First Exploitation:
                  </span>
                  <span class="p-value">
                    {{moment-format vulnerability.exploitation.first_exploitation "YYYY-MM-DD" timeZone=timezone}}
                  </span>
                </div>
              {{/if}}
              {{#if vulnerability.cisa_known_exploited}}
                {{#if vulnerability.cisa_known_exploited.added_date}}
                  <div>
                    <span class="p-key">
                      CISA KEV Added:
                    </span>
                    <span class="p-value">
                      {{moment-format vulnerability.cisa_known_exploited.added_date "YYYY-MM-DD" timeZone=timezone}}
                    </span>
                  </div>
                {{/if}}
                {{#if vulnerability.cisa_known_exploited.due_date}}
                  <div>
                    <span class="p-key">
                      CISA KEV Due Date:
                    </span>
                    <span class="p-value">
                      {{moment-format vulnerability.cisa_known_exploited.due_date "YYYY-MM-DD" timeZone=timezone}}
                    </span>
                  </div>
                {{/if}}
                {{#if vulnerability.cisa_known_exploited.ransomware_use}}
                  <div>
                    <span class="p-key">
                      Ransomware Use:
                    </span>
                    <span class="p-value">
                      {{vulnerability.cisa_known_exploited.ransomware_use}}
                    </span>
                  </div>
                {{/if}}
              {{/if}}
            {{/if}}

            {{! IDENTIFIERS & CLASSIFICATION - Individual Fields }}
            {{#if
              (not
                (or
                  (and vulnerability.cve_id vulnerability.mve_id)
                  (and vulnerability.cve_id vulnerability.cwe.title)
                  (and vulnerability.cve_id vulnerability.cvssVector)
                  (and vulnerability.mve_id vulnerability.cwe.title)
                  (and vulnerability.mve_id vulnerability.cvssVector)
                  (and vulnerability.cwe.title vulnerability.cvssVector)
                )
              )
            }}
              {{#if vulnerability.cve_id}}
                <div>
                  <span class="p-key">
                    CVE ID:
                  </span>
                  <span class="p-value">
                    {{vulnerability.cve_id}}
                  </span>
                </div>
              {{/if}}
              {{#if vulnerability.mve_id}}
                <div>
                  <span class="p-key">
                    MVE ID:
                  </span>
                  <span class="p-value">
                    {{vulnerability.mve_id}}
                  </span>
                </div>
              {{/if}}
              {{#if vulnerability.cwe.title}}
                <div>
                  <span class="p-key">
                    CWE:
                  </span>
                  <span class="p-value">
                    {{vulnerability.cwe.title}}{{#if vulnerability.cwe.id}}
                      ({{vulnerability.cwe.id}})
                    {{/if}}
                  </span>
                </div>
              {{/if}}
              {{#if vulnerability.cvssVector}}
                <div>
                  <span class="p-key">
                    CVSS Vector:
                  </span>
                  <span class="p-value">
                    {{vulnerability.cvssVector}}
                  </span>
                </div>
              {{/if}}
            {{/if}}

            {{! EXPLOITATION STATUS & METRICS - Individual Fields }}
            {{#if
              (not
                (or
                  (and vulnerability.exploitation_state vulnerability.exploitabilityMetrics.daysToExploit)
                  (and vulnerability.exploitation_state vulnerability.exploitation_vectors)
                  (and vulnerability.exploitation_state vulnerability.exploitation_consequence)
                  (and vulnerability.exploitabilityMetrics.daysToExploit vulnerability.exploitation_vectors)
                  (and vulnerability.exploitabilityMetrics.daysToExploit vulnerability.exploitation_consequence)
                  (and vulnerability.exploitation_vectors vulnerability.exploitation_consequence)
                )
              )
            }}
              {{#if vulnerability.exploitation_state}}
                <div>
                  <span class="p-key">
                    Exploitation Status:
                  </span>
                  <span class="p-value">
                    {{vulnerability.exploitation_state}}{{#if vulnerability.exploit_availability}}
                      - {{vulnerability.exploit_availability}}
                    {{/if}}
                  </span>
                </div>
              {{/if}}
              {{#if vulnerability.exploitabilityMetrics.daysToExploit}}
                <div>
                  <span class="p-key">
                    Days to Exploit:
                  </span>
                  <span class="p-value">
                    {{vulnerability.exploitabilityMetrics.daysToExploit}} days
                  </span>
                </div>
              {{/if}}
              {{#if vulnerability.exploitation_vectors}}
                <div>
                  <span class="p-key">
                    Attack Vectors:
                  </span>
                  <span class="p-value">
                    {{join ", " vulnerability.exploitation_vectors}}
                  </span>
                </div>
              {{/if}}
              {{#if vulnerability.exploitation_consequence}}
                <div>
                  <span class="p-key">
                    Impact:
                  </span>
                  <span class="p-value">
                    {{vulnerability.exploitation_consequence}}
                  </span>
                </div>
              {{/if}}
            {{/if}}

            {{! AFFECTED SYSTEMS & PRODUCTS - Individual Fields }}
            {{#if (not vulnerability.cpes)}}
              {{#if vulnerability.targetedIndustryNames}}
                <div class="metadata-field">
                  <span class="p-key">
                    Industries:
                  </span>
                  <span class="p-value">
                    {{join " | " vulnerability.targetedIndustryNames}}
                  </span>
                </div>
              {{/if}}
              {{#if vulnerability.impactSummary.systems}}
                <div class="metadata-field">
                  <span class="p-key">
                    System Types:
                  </span>
                  <span class="p-value">
                    {{join " | " vulnerability.impactSummary.systems}}
                  </span>
                </div>
              {{/if}}
              {{#if vulnerability.exploitation_vectors}}
                <div>
                  <span class="p-key">
                    Attack Vectors:
                  </span>
                  <span class="p-value">
                    {{join " | " vulnerability.exploitation_vectors}}
                  </span>
                </div>
              {{/if}}
              {{#if vulnerability.exploitation_consequence}}
                <div>
                  <span class="p-key">
                    Potential Impact:
                  </span>
                  <span class="p-value">
                    {{vulnerability.exploitation_consequence}}
                  </span>
                </div>
              {{/if}}
            {{/if}}

            {{! REMEDIATION & MITIGATION - Individual Fields }}
            {{#if
              (not
                (or
                  (and vulnerability.available_mitigation vulnerability.mitigationDetails.length)
                  (and vulnerability.available_mitigation vulnerability.timeToMitigation)
                  (and vulnerability.mitigationDetails.length vulnerability.timeToMitigation)
                )
              )
            }}
              {{#if vulnerability.available_mitigation}}
                <div>
                  <span class="p-key">
                    Available Mitigations:
                  </span>
                  <span class="p-value">
                    {{join ", " vulnerability.available_mitigation}}
                  </span>
                </div>
              {{/if}}
              {{#if vulnerability.timeToMitigation}}
                <div>
                  <span class="p-key">
                    Time to Mitigation:
                  </span>
                  <span class="p-value">
                    {{vulnerability.timeToMitigation}} days
                  </span>
                </div>
              {{/if}}
            {{/if}}

            {{! REMEDIATION & MITIGATION - Individual Fields 2 }}
            {{#if
              (and
                vulnerability.mitigationDetails.length
                (not
                  (or
                    (and vulnerability.available_mitigation vulnerability.mitigationDetails.length)
                    (and vulnerability.available_mitigation vulnerability.timeToMitigation)
                    (and vulnerability.mitigationDetails.length vulnerability.timeToMitigation)
                  )
                )
              )
            }}
              <div>
                <div class="p-key confidence-metadata-title">
                  Vendor Fix References
                  {{#if (gt vulnerability.mitigationDetails.length 1)}}
                    ({{vulnerability.mitigationDetails.length}})
                  {{/if}}
                </div>
                <div class="scrollable-block short bordered">
                  {{#each (take 100 vulnerability.mitigationDetails) as |fix|}}
                    <div class="scrollable-block-list-item">
                      {{#if fix.url}}
                        <a href="{{fix.url}}" target="_blank">
                          {{or fix.title fix.name fix.source_description fix.cvss fix.unique_id fix.url}}
                        </a>
                      {{else}}
                        {{or fix.title fix.name fix.source_description fix.cvss fix.unique_id}}
                      {{/if}}
                      {{#if fix.published_date}}
                        <span class="p-value">
                          - {{moment-format fix.published_date "YYYY-MM-DD" timeZone=timezone}}
                        </span>
                      {{/if}}
                    </div>
                  {{/each}}
                  {{#if (gt vulnerability.mitigationDetails.length 100)}}
                    <span class="p-value">
                      ...
                    </span>
                  {{/if}}
                </div>
                {{#if (gt vulnerability.mitigationDetails.length 10)}}
                  <div>
                    <a
                      href="https://www.virustotal.com/gui/collection/{{
                        vulnerability.id
                      }}/products-and-fixes/vendor-fix-details"
                    >
                      View all Vendor Fix References in GTI
                      <svg
                        class="gti-icon"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path
                          d="M12.0014 8.57257C11.4758 8.57257 10.9845 8.69824 10.5274 8.9153L12.7784 11.1659C12.9955 11.3715 13.1327 11.6686 13.1327 11.9999H15.418C15.418 10.1149 13.8754 8.57257 11.99 8.57257H12.0014Z"
                          fill="#FBBC04"
                        ></path>
                        <path
                          d="M12.0014 13.1423C11.373 13.1423 10.8588 12.6282 10.8588 11.9999H8.57347C8.57347 13.8849 10.1161 15.4271 12.0014 15.4271C13.8868 15.4271 15.4294 13.8849 15.4294 11.9999H13.1441C13.1441 12.6282 12.6299 13.1423 12.0014 13.1423Z"
                          fill="#34A853"
                        ></path>
                        <path
                          d="M14.4696 17.1408C13.3498 17.6777 12.0357 17.8719 10.6531 17.5521C8.5849 17.0722 6.92805 15.4043 6.44813 13.3479C6.3453 12.891 6.28816 12.4454 6.28816 11.9999H4.00286C4.00286 12.4911 4.04856 12.9938 4.13997 13.4964C4.73415 16.6952 7.30512 19.2657 10.5046 19.8598C12.2757 20.1911 13.9668 19.9169 15.4065 19.2314C16.1264 18.8887 16.3207 17.9405 15.7493 17.3807C15.4065 17.038 14.8923 16.9466 14.4696 17.1522V17.1408Z"
                          fill="#4285F4"
                        ></path>
                        <path
                          d="M19.223 15.4157C19.7143 14.3761 20 13.2223 20 11.9999H17.7147C17.7147 12.8795 17.509 13.7135 17.1548 14.4561C16.9491 14.8902 17.0291 15.4043 17.3719 15.747C17.9318 16.3068 18.8802 16.1355 19.223 15.4043V15.4157Z"
                          fill="#4285F4"
                        ></path>
                        <path
                          d="M13.3041 4.10567C12.6185 3.99143 12.0014 4.55122 12.0014 5.2481C12.0014 5.80789 12.4128 6.27629 12.9727 6.36768C15.6579 6.83608 17.7147 9.17806 17.7147 11.9999H20C20 8.03563 17.0977 4.73401 13.3041 4.10567Z"
                          fill="#FBBC04"
                        ></path>
                        <path
                          d="M10.5274 8.9153L5.95679 4.33416C5.51116 3.88861 4.77986 3.88861 4.33423 4.33416C3.88859 4.77971 3.88859 5.51086 4.33423 5.95641L5.60257 7.22451C4.60846 8.54972 4.00286 10.2062 4.00286 11.9999H6.28816C6.28816 10.8346 6.64239 9.7607 7.23656 8.85818L8.90484 10.5261C8.68773 10.9717 8.56204 11.4743 8.56204 11.9999H10.8473C10.8473 11.3715 11.3615 10.8574 11.99 10.8574C12.2871 10.8574 12.5728 10.9831 12.7784 11.1659L10.5274 8.9153Z"
                          fill="#EA4335"
                        ></path>
                      </svg>
                    </a>
                  </div>
                {{/if}}
              </div>
            {{/if}}
            {{! DROPDOWN ALT FIELD DISPLAYS END }}

            {{! ANALYSIS - Dropdown }}
            {{#if vulnerability.htmlAnalysis}}
              <div class="toggle-header">
                <span class="p-action" {{action "toggleExpandableAssociations" "vulnAnalysis" vulnIndex}}>
                  {{fa-icon "book" fixedWidth=true}}
                  Analysis
                  {{fa-icon
                    (if (get expandedAssociations (concat "vulnAnalysis" vulnIndex)) "caret-up" "caret-down")
                    fixedWidth=true
                  }}
                </span>
              </div>
              {{#if (get expandedAssociations (concat "vulnAnalysis" vulnIndex))}}
                <div class="scrollable-block mt-1 bordered">
                  {{{vulnerability.htmlAnalysis}}}
                </div>
              {{/if}}
            {{/if}}

            {{! CRITICAL TIMELINE - Dropdown }}
            {{#if
              (or
                (and vulnerability.cisa_known_exploited vulnerability.date_of_disclosure)
                (and vulnerability.cisa_known_exploited vulnerability.exploitation.first_exploitation)
                (and vulnerability.date_of_disclosure vulnerability.exploitation.first_exploitation)
              )
            }}
              <div class="toggle-header">
                <span class="p-action" {{action "toggleExpandableAssociations" "vulnTimeline" vulnIndex}}>
                  {{fa-icon "clock" fixedWidth=true}}
                  Critical Timeline
                  {{fa-icon
                    (if (get expandedAssociations (concat "vulnTimeline" vulnIndex)) "caret-up" "caret-down")
                    fixedWidth=true
                  }}
                </span>
              </div>
              {{#if (get expandedAssociations (concat "vulnTimeline" vulnIndex))}}
                <div class="mt-1">
                  {{#if vulnerability.date_of_disclosure}}
                    <div>
                      <span class="p-key">
                        Disclosure Date:
                      </span>
                      <span class="p-value">
                        {{moment-format vulnerability.date_of_disclosure "YYYY-MM-DD" timeZone=timezone}}
                      </span>
                    </div>
                  {{/if}}
                  {{#if vulnerability.exploitation.first_exploitation}}
                    <div>
                      <span class="p-key">
                        First Exploitation:
                      </span>
                      <span class="p-value">
                        {{moment-format vulnerability.exploitation.first_exploitation "YYYY-MM-DD" timeZone=timezone}}
                      </span>
                    </div>
                  {{/if}}
                  {{#if vulnerability.cisa_known_exploited}}
                    {{#if vulnerability.cisa_known_exploited.added_date}}
                      <div>
                        <span class="p-key">
                          CISA KEV Added:
                        </span>
                        <span class="p-value">
                          {{moment-format vulnerability.cisa_known_exploited.added_date "YYYY-MM-DD" timeZone=timezone}}
                        </span>
                      </div>
                    {{/if}}
                    {{#if vulnerability.cisa_known_exploited.due_date}}
                      <div>
                        <span class="p-key">
                          CISA KEV Due Date:
                        </span>
                        <span class="p-value">
                          {{moment-format vulnerability.cisa_known_exploited.due_date "YYYY-MM-DD" timeZone=timezone}}
                        </span>
                      </div>
                    {{/if}}
                    {{#if vulnerability.cisa_known_exploited.ransomware_use}}
                      <div>
                        <span class="p-key">
                          Ransomware Use:
                        </span>
                        <span class="p-value">
                          {{vulnerability.cisa_known_exploited.ransomware_use}}
                        </span>
                      </div>
                    {{/if}}
                  {{/if}}
                </div>
              {{/if}}
            {{/if}}

            {{! IDENTIFIERS & CLASSIFICATION - Dropdown }}
            {{#if
              (or
                (and vulnerability.cve_id vulnerability.mve_id)
                (and vulnerability.cve_id vulnerability.cwe.title)
                (and vulnerability.cve_id vulnerability.cvssVector)
                (and vulnerability.mve_id vulnerability.cwe.title)
                (and vulnerability.mve_id vulnerability.cvssVector)
                (and vulnerability.cwe.title vulnerability.cvssVector)
              )
            }}
              <div class="toggle-header">
                <span class="p-action" {{action "toggleExpandableAssociations" "vulnIdentifiers" vulnIndex}}>
                  {{fa-icon "id-badge" fixedWidth=true}}
                  Identifiers & Classification
                  {{fa-icon
                    (if (get expandedAssociations (concat "vulnIdentifiers" vulnIndex)) "caret-up" "caret-down")
                    fixedWidth=true
                  }}
                </span>
              </div>
              {{#if (get expandedAssociations (concat "vulnIdentifiers" vulnIndex))}}
                <div class="mt-1">
                  {{#if vulnerability.cve_id}}
                    <div>
                      <span class="p-key">
                        CVE ID:
                      </span>
                      <span class="p-value">
                        {{vulnerability.cve_id}}
                      </span>
                    </div>
                  {{/if}}
                  {{#if vulnerability.mve_id}}
                    <div>
                      <span class="p-key">
                        MVE ID:
                      </span>
                      <span class="p-value">
                        {{vulnerability.mve_id}}
                      </span>
                    </div>
                  {{/if}}
