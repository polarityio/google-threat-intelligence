              <path d="M10.65 14.854 16.194 9.4 15.15 8.356l-4.5 4.39-1.8-1.74-1.044 1.044 2.844 2.804Zm1.36 6.646a1.376 1.376 0 0 1-.63-.16c-2.243-1.177-3.95-2.691-5.122-4.544C5.086 14.944 4.5 12.778 4.5 10.3V6.412c0-.389.11-.739.329-1.05.22-.312.51-.531.871-.658l5.692-2.064a22.1 22.1 0 0 1 .304-.095c.099-.03.2-.045.304-.045.17 0 .372.047.608.14L18.3 4.694c.361.127.652.345.871.655.22.31.329.659.329 1.047V10.3c0 2.472-.594 4.636-1.78 6.494-1.188 1.858-2.89 3.373-5.105 4.546-.093.05-.19.09-.29.118-.1.028-.205.042-.315.042ZM12 19.973c1.94-1.055 3.425-2.387 4.455-3.996C17.485 14.367 18 12.476 18 10.3V6.387a.299.299 0 0 0-.053-.174.32.32 0 0 0-.149-.115l-5.692-2.044a.282.282 0 0 0-.106-.02.283.283 0 0 0-.106.02L6.202 6.098a.319.319 0 0 0-.15.115.298.298 0 0 0-.052.174V10.3c0 2.176.515 4.07 1.545 5.685 1.03 1.614 2.515 2.943 4.455 3.988Z"></path>
